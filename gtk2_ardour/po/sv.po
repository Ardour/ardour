msgstr "Grid växlar till alternativt val för interna redigeringsverktyg"

#: rc_option_editor.cc:3509
msgid "Grid mode selection may change ruler visibility"
msgstr "Val av rutnätsläge kan ändra linjalens synlighet"

#: rc_option_editor.cc:3518
msgid "Rulers automatically change to follow the Grid mode selection"
msgstr "Linjalerna ändras automatiskt för att följa valet av rutnätsläge"

#: rc_option_editor.cc:3533
