#: opts.cc:70
msgid "Options:\n"
msgstr "Flaggor:\n"

#: opts.cc:71
msgid ""
"  -a, --no-announcements      Do not contact website for announcements\n"
msgstr ""
"  -a, --no-announcements      Kontakta inte webbplatsen för meddelanden\n"

#: opts.cc:72
msgid "  -A, --actions               Print all possible menu action names\n"
msgstr "  -A, --actions               Skriv ut alla möjliga menyåtgärdsnamn\n"

#: opts.cc:73
msgid "  -b, --bindings              Display all current key bindings\n"
msgstr "  -b, --bindings              Visa alla aktuella tangentbindningar\n"

#: opts.cc:74
msgid ""
"  -B, --bypass-plugins        Bypass all plugins in an existing session\n"
msgstr ""
"  -B, --bypass-plugins        Kringgå alla tillägg i en befintlig session\n"

#: opts.cc:75
msgid ""
"  -c, --name <name>           Use a specific backend client name, default is "
"ardour\n"
msgstr ""
"  -c, --name <name>          Använd ett specifikt backend-klientnamn, "
"standard är ardour\n"

#: opts.cc:76
msgid "  -d, --disable-plugins       Disable all plugins (safe mode)\n"
msgstr "  -d, --disable-plugins       Inaktivera alla tillägg (säkert läge)\n"

#: opts.cc:78
msgid ""
"  -D, --debug <options>       Set debug flags. Use \"-D list\" to see "
"available options\n"
msgstr ""
"  -D, --debug <alternativ>      Ställ in felsökningsflaggor. Använd \"-D "
"list\" för att se tillgängliga alternativ.\n"

#: opts.cc:80
msgid "  -h, --help                  Print this message\n"
msgstr "  -h, --help                  Skriv ut detta meddelande\n"

#: opts.cc:81
msgid "  -k, --keybindings <file>    Path to the key bindings file to load\n"
msgstr ""
"  -k, --keybindings <fil>   Sökväg till filen med tangentbindningar som ska "
"laddas\n"

#: opts.cc:82
msgid "  -m, --menus file            Use \"file\" to define menus\n"
msgstr ""
"  -m, --menus fil             Använd \"fil\" för att definiera menyer\n"

#: opts.cc:83
msgid "  -n, --no-splash             Do not show splash screen\n"
msgstr "  -n, --no-splash             Visa inte startskärmen\n"

#: opts.cc:85
msgid "  -O, --no-hw-optimizations   Disable h/w specific optimizations\n"
msgstr ""
"  -O, --no-hw-optimizations   Inaktivera hårdvaruspecifika optimeringar\n"

#: opts.cc:86
msgid "  -P, --no-connect-ports      Do not connect any ports at startup\n"
msgstr "  -P, --no-connect-ports      Anslut inga portar vid start\n"

#: opts.cc:87
msgid "  -s, --no-strobe             Avoid \"strobe-like\" effects in GUI\n"
msgstr "  -s, --no-strobe Undvik \"stroboskopliknande\" effekter i GUI\n"

#: opts.cc:88
msgid "  -S, --sync                  Draw the GUI synchronously\n"
msgstr "  -S, --sync                  Rita grafiska gränssnittet synkront\n"

#: opts.cc:89
msgid "  -T, --template <name>       Use given template for new session\n"
msgstr "  -T, --template <name>      Använd given mall för ny session\n"

#: opts.cc:90
msgid "  -v, --version               Print version and exit\n"
msgstr "  -v, --version               Skriv ut version och avsluta\n"

#: opts.cc:92
msgid "Report bugs to http://tracker.ardour.org\n"
msgstr "Rapportera fel till http://tracker.ardour.org\n"

#: opts.cc:93
msgid "Website http://ardour.org\n"
msgstr "Webbplats http://ardour.org\n"

