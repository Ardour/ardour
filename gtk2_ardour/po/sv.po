#: add_route_dialog.cc:102 add_route_dialog.cc:591 add_route_dialog.cc:612
#: add_route_dialog.cc:618
msgid "Audio Tracks"
msgstr "Ljudspår"

#: add_route_dialog.cc:103
msgid "Use these settings to create one or more audio tracks."
msgstr "Använd dessa inställningar för att skapa ett eller flera ljudspår."

#: add_route_dialog.cc:104 add_route_dialog.cc:117 add_route_dialog.cc:130
#: add_route_dialog.cc:143 add_route_dialog.cc:156 add_route_dialog.cc:164
msgid "You may select:"
msgstr "Du kan välja:"

#: add_route_dialog.cc:105 add_route_dialog.cc:118
msgid "The number of tracks to add"
msgstr "Antalet spår som ska läggas till"

#: add_route_dialog.cc:106 add_route_dialog.cc:119
msgid "A name for the track(s)"
msgstr "Ett namn för spåret/spåren"

#: add_route_dialog.cc:107
msgid "Mono, stereo, or multi-channel operation for the track(s)"
msgstr "Mono-, stereo- eller flerkanalsdrift för spåret/spåren"

#: add_route_dialog.cc:108 add_route_dialog.cc:121
msgid "A group which the track(s) will be assigned to"
msgstr "En grupp som spåret/spåren kommer att tilldelas"

#: add_route_dialog.cc:110 add_route_dialog.cc:123 add_route_dialog.cc:135
#: add_route_dialog.cc:149
msgid "The pin connections mode (see tooltip for details)"
msgstr "Stiftanslutningsläget (se verktygstips för mer information)"

#: add_route_dialog.cc:112 add_route_dialog.cc:125
msgid "The track(s) will be added at the location specified by \"Position\""
msgstr "Spåret/spåren läggs till på den plats som anges under \"Position\"."

#: add_route_dialog.cc:115 add_route_dialog.cc:589 add_route_dialog.cc:610
msgid "MIDI Tracks"
msgstr "MIDI-spår"

#: add_route_dialog.cc:116
msgid "Use these settings to create one or more MIDI tracks."
msgstr "Använd dessa inställningar för att skapa ett eller flera MIDI-spår."

#: add_route_dialog.cc:120 add_route_dialog.cc:146
msgid "An instrument plugin (or select \"None\" to drive an external device)"
msgstr ""
"Ett instrument-insticksmodul (eller välj \"Inget\" för att styra en extern "
"enhet)"

#: add_route_dialog.cc:128 add_route_dialog.cc:585 add_route_dialog.cc:606
msgid "Audio Busses"
msgstr "Ljudbussar"

#: add_route_dialog.cc:129
msgid "Use these settings to create one or more audio busses."
msgstr "Använd dessa inställningar för att skapa en eller flera ljudbussar."

#: add_route_dialog.cc:131 add_route_dialog.cc:144 add_route_dialog.cc:165
msgid "The number of busses to add"
msgstr "Antalet bussar som ska läggas till"

#: add_route_dialog.cc:132 add_route_dialog.cc:145 add_route_dialog.cc:166
msgid "A name for the buss(es)"
msgstr "Ett namn för bussen/bussarna"

#: add_route_dialog.cc:133 add_route_dialog.cc:147
msgid "A group which the buss(es) will be assigned to"
msgstr "En grupp som bussen/bussarna kommer att tilldelas"

#: add_route_dialog.cc:137 add_route_dialog.cc:151
msgid "The buss(es) will be added at the location specified by \"Position\""
msgstr ""
"Bussen/bussarna kommer att läggas till på den plats som anges under "
"\"Position\"."

#: add_route_dialog.cc:140 add_route_dialog.cc:587 add_route_dialog.cc:608
msgid "MIDI Busses"
msgstr "MIDI-bussar"

#: add_route_dialog.cc:141
msgid "Use these settings to create one or more MIDI busses."
msgstr "Använd dessa inställningar för att skapa en eller flera MIDI-bussar."

#: add_route_dialog.cc:142
msgid ""
"MIDI busses can combine the output of multiple tracks. They are sometimes "
"used\n"
"to host a single \"heavy\" instrument plugin which is fed from multiple MIDI "
"tracks."
msgstr ""
"MIDI-bussar kan kombinera utsignalen från flera spår. De används ibland för "
"att hysa ett enda \"tungt\" instrument-insticksmodul som matas från flera "
"MIDI-spår."

#: add_route_dialog.cc:154 add_route_dialog.cc:593 add_route_dialog.cc:614
msgid "VCA Masters"
msgstr "VCA Masters"

#: add_route_dialog.cc:155
msgid "Use these settings to create one or more VCA masters."
msgstr "Använd dessa inställningar för att skapa en eller flera VCA-masters."

#: add_route_dialog.cc:157
msgid "The number of VCAs to add"
msgstr "Antalet VCA:er som ska läggas till"

#: add_route_dialog.cc:158
#, c-format
msgid ""
"A name for the VCA(s). \"%n\" will be replaced by an index number for each "
"VCA"
msgstr ""
"Ett namn för VCA:erna. \"%n\" kommer att ersättas av ett indexnummer för "
"varje VCA"

#: add_route_dialog.cc:161 add_route_dialog.cc:595 add_route_dialog.cc:616
msgid "Foldback Busses"
msgstr "Foldback-bussar"

#: add_route_dialog.cc:162
msgid "Use these settings to create one or more foldback busses."
msgstr ""
"Använd dessa inställningar för att skapa en eller flera foldback-bussar."

#: add_route_dialog.cc:163
msgid ""
"Foldback busses are used as master outputs for monitor channels and are fed "
"by\n"
"hidden monitor sends."
msgstr ""
"Foldback-bussar används som masterutgångar för monitorkanaler och matas av "
"dolda monitorsändningar."

