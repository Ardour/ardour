#: rc_option_editor.cc:4313 rc_option_editor.cc:4322 rc_option_editor.cc:4323
#: rc_option_editor.cc:4328 rc_option_editor.cc:4346 rc_option_editor.cc:4349
#: rc_option_editor.cc:4350
msgid "Plugins/VST"
msgstr "insticksmoduler/VST"

#: rc_option_editor.cc:4270
